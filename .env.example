# ── Server ────────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ── MongoDB ───────────────────────────────────────────────────────────────────
MONGODB_URI=
MONGODB_URI_TEST=

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_URI=

# ── Seed ──────────────────────────────────────────────────────────────────────
SEED_ADMIN_EMAIL=
SEED_ADMIN_NOMBRE=
SEED_USER2_EMAIL=
SEED_USER2_NOMBRE=
SEED_USER2_ROLE=

SEED_USER3_EMAIL=
SEED_USER3_NOMBRE=
SEED_USER3_ROLE=

# ── Auth0 ─────────────────────────────────────────────────────────────────────
AUTH0_DOMAIN=
AUTH0_AUDIENCE=

# ── JWT ───────────────────────────────────────────────────────────────────────
JWT_SECRET=
JWT_EXPIRES_IN=24h

# ── SAT Web Services ──────────────────────────────────────────────────────────
SAT_ENDPOINT=
SAT_VERIFICA_CFDI_WSDL=
SAT_DESCARGA_MASIVA_AUTENTICACION=
SAT_DESCARGA_MASIVA_SOLICITUD=
SAT_DESCARGA_MASIVA_VERIFICA=
SAT_DESCARGA_MASIVA_DESCARGA=

# ── Credenciales / e.firma ────────────────────────────────────────────────────
# Generar con: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CREDS_MASTER_KEY=

# ── FIEL (requerida para Descarga Masiva) ─────────────────────────────────────
FIEL_CER_PATH=./certs/fiel.cer
FIEL_KEY_PATH=./certs/fiel.key
FIEL_KEY_PASSWORD=

# ── RFC ───────────────────────────────────────────────────────────────────────
COMPANY_RFC=
RFCS_ACTIVOS=

# ── ERP Integration ───────────────────────────────────────────────────────────
ERP_CAJA_BASE_URL=
ERP_FACT_BASE_URL=
ERP_TOKEN=
ERP_API_BASE_URL=
ERP_API_TOKEN=

# ── Google / Cloud ────────────────────────────────────────────────────────────
GOOGLE_SERVICE_ACCOUNT_KEY_PATH=
GOOGLE_SERVICE_ACCOUNT_KEY=
GOOGLE_SERVICE_ACCOUNT_JSON=
GOOGLE_DRIVE_ROOT_FOLDER_ID=
GOOGLE_DRIVE_ERP_FOLDER_ID=

# ── OCR / Análisis de comprobantes ────────────────────────────────────────────
# Opciones: 'tesseract' (local, gratis) | 'claude' (API, mayor precisión)
RECEIPT_OCR_ENGINE=tesseract
ANTHROPIC_API_KEY=
ANTHROPIC_VISION_MODEL=
GEMINI_API_KEY=

# ── Rate Limiting / CORS ──────────────────────────────────────────────────────
CORS_ORIGIN=http://localhost:4200
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# ── Logs ──────────────────────────────────────────────────────────────────────
LOG_LEVEL=info
LOG_FILE=logs/app.log

# ── Cron — Descarga Masiva SAT ────────────────────────────────────────────────
# Formato cron. Por defecto: 1:00 AM hora de México
CRON_HORA= 0 23 * * *
